    if (rand < pack.dropRates.basic) {
      rarity = 'Basic';
    } else if (rand < pack.dropRates.basic + pack.dropRates.rare) {
      rarity = 'Rare';
    } else if (rand < pack.dropRates.basic + pack.dropRates.rare + pack.dropRates.unique) {
      rarity = 'Unique';
    } else {
      rarity = 'Legendary_Common';
    }
    
