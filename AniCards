const packsRoutes = `
const express = require('express');
const router = express.Router();
const Pack = require('../models/Pack');
const Card = require('../models/Card');
const CardInventory = require('../models/CardInventory');
const User = require('../models/User');
const { verifyToken } = require('../middleware/auth');

// Get all packs
router.get('/', async (req, res) => {
  try {
    const packs = await Pack.find({ isActive: true });
    res.json({
      success: true,
      packs: packs
    });
  } catch (error) {
    res.status(500).json({
      error: 'Failed to fetch packs'
    });
  }
});

// Open pack
router.post('/open', verifyToken, async (req, res) => {
  try {
    const { packType } = req.body;
    const userId = req.user.id;

    const pack = await Pack.findOne({ name: packType });
    if (!pack) {
      return res.status(404).json({
        error: 'Pack not found'
      });
    }

    const user = await User.findById(userId);
    if (user.berryBalance < pack.costInBerries) {
      return res.status(400).json({
        error: 'Insufficient berries'
      });
    }

    user.berryBalance -= pack.costInBerries;

    // Generate random cards
    const cards = await generatePackCards(pack, userId);

    for (const card of cards) {
      await CardInventory.create({
        userId: user._id,
        cardId: card._id,
        condition: 'Mint',
        acquiredDate: new Date(),
        acquiredFrom: 'Pack',
        currentValue: card.currentValue,
        originalValue: card.currentValue
      });
    }

