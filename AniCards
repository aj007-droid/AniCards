const express = require('express');
const router = express.Router();
const Card = require('../models/Card');
const CardValuation = require('../models/CardValuation');
const { verifyToken } = require('../middleware/auth');

// Get all cards
router.get('/', async (req, res) => {
  try {
    const { rarity, type, search } = req.query;
    let query = { isActive: true };

    if (rarity) query.rarity = rarity;
    if (type) query.type = type;
    if (search) {
      query.\$or = [
        { name: { \$regex: search, \$options: 'i' } },
        { character: { \$regex: search, \$options: 'i' } },
        { description: { \$regex: search, \$options: 'i' } }
      ];
    }

    const cards = await Card.find(query).limit(100);

    res.json({
      success: true,
      count: cards.length,
      cards: cards
    });
  } catch (error) {
    console.error('Get cards error:', error);
    res.status(500).json({
      error: 'Failed to get cards'
    });
  }
});

// Get single card with valuation
router.get('/:cardId', async (req, res) => {
  try {
    const card = await Card.findById(req.params.cardId);
    if (!card) {
      return res.status(404).json({
        error: 'Card not found'
      });
    }

    const valuation = await CardValuation.findOne({ cardId: card._id });

    res.json({
      success: true,
      card: card,
      valuation: valuation
    });
  } catch (error) {
    console.error('Get card error:', error);
    res.status(500).json({
      error: 'Failed to get card'
    });
  }
});

module.exports = router;
`;

